<svg width="192" height="192" viewBox="0 0 192 192" fill="none" xmlns="http://www.w3.org/2000/svg">
<!-- Background circle -->
<circle cx="96" cy="96" r="96" fill="url(#logoBg)"/>

<!-- Shadow Milk Cookie character -->
<!-- Body -->
<ellipse cx="96" cy="110" rx="32" ry="38" fill="#87CEEB"/>
<ellipse cx="96" cy="105" rx="28" ry="34" fill="#B0E0E6"/>

<!-- Spiky blue hair -->
<path d="M68 70 L75 55 L82 70 L90 50 L98 70 L106 55 L114 70 L122 60 L124 75" fill="#4682B4"/>

<!-- White curved detail on head -->
<path d="M78 78 Q96 68 114 78 Q96 85 78 78" fill="#FFFFFF"/>

<!-- Eyes -->
<circle cx="84" cy="92" r="6" fill="#000"/>
<circle cx="108" cy="92" r="6" fill="#000"/>
<circle cx="86" cy="90" r="2" fill="#FFF"/>
<circle cx="110" cy="90" r="2" fill="#FFF"/>

<!-- Nose -->
<ellipse cx="96" cy="102" rx="3" ry="2" fill="#4169E1"/>

<!-- Mischievous smile -->
<path d="M86 112 Q96 122 106 112" stroke="#000" stroke-width="2" fill="none"/>

<!-- Dark outfit -->
<rect x="78" y="125" width="36" height="28" rx="6" fill="#2F4F4F"/>
<rect x="90" y="130" width="12" height="15" rx="2" fill="#4682B4"/>

<!-- Decorative elements around -->
<!-- Hearts indicating care -->
<path d="M40 50 Q35 45 30 50 Q25 45 20 50 Q20 55 30 65 Q40 55 40 50" fill="#FF69B4" opacity="0.8"/>
<path d="M172 140 Q169 137 166 140 Q163 137 160 140 Q160 143 166 150 Q172 143 172 140" fill="#FF1493" opacity="0.8"/>

<!-- Stars for magic/fun -->
<path d="M50 150 L52 156 L58 156 L53 160 L55 166 L50 162 L45 166 L47 160 L42 156 L48 156 Z" fill="#FFD700" opacity="0.9"/>
<path d="M142 40 L144 46 L150 46 L145 50 L147 56 L142 52 L137 56 L139 50 L134 46 L140 46 Z" fill="#FFD700" opacity="0.9"/>

<!-- Small sparkles -->
<circle cx="30" cy="80" r="2" fill="#FFF" opacity="0.7"/>
<circle cx="162" cy="70" r="2" fill="#FFF" opacity="0.7"/>
<circle cx="40" cy="120" r="1.5" fill="#FFF" opacity="0.8"/>
<circle cx="152" cy="110" r="1.5" fill="#FFF" opacity="0.8"/>

<!-- Border ring -->
<circle cx="96" cy="96" r="94" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>

<defs>
<linearGradient id="logoBg" x1="0%" y1="0%" x2="100%" y2="100%">
<stop offset="0%" stop-color="#4B5563"/>
<stop offset="30%" stop-color="#6B7280"/>
<stop offset="70%" stop-color="#374151"/>
<stop offset="100%" stop-color="#1F2937"/>
</linearGradient>
</defs>
</svg>