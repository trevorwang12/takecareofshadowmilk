<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<!-- Shadow Milk Cookie favicon 16x16 -->
<rect width="16" height="16" rx="2" fill="url(#shadowGradient)"/>

<!-- Cookie shape -->
<circle cx="8" cy="8" r="5" fill="rgba(139,69,19,0.8)"/>
<circle cx="8" cy="8" r="3.5" fill="rgba(160,82,45,0.9)"/>

<!-- Spiky hair -->
<path d="M6 4 L6.5 2 L7 4 L7.5 1.5 L8 4 L8.5 2 L9 4 L9.5 1.5 L10 4" stroke="rgba(70,130,180,0.8)" stroke-width="0.5" fill="none"/>

<!-- Eyes (mischievous) -->
<circle cx="6.5" cy="6.5" r="0.5" fill="rgba(255,255,255,0.9)"/>
<circle cx="9.5" cy="6.5" r="0.5" fill="rgba(255,255,255,0.9)"/>
<circle cx="6.6" cy="6.4" r="0.2" fill="rgba(255,20,147,0.8)"/>
<circle cx="9.4" cy="6.4" r="0.2" fill="rgba(255,20,147,0.8)"/>

<!-- Mouth (mischievous grin) -->
<path d="M6.5 9 Q8 10.5 9.5 9" stroke="rgba(255,255,255,0.8)" stroke-width="0.3" fill="none"/>

<!-- Cookie crumbs -->
<circle cx="5" cy="10" r="0.3" fill="rgba(139,69,19,0.6)"/>
<circle cx="11" cy="10.5" r="0.2" fill="rgba(160,82,45,0.5)"/>

<!-- Dark sparkles -->
<circle cx="3" cy="3" r="0.2" fill="rgba(255,255,255,0.7)"/>
<circle cx="13" cy="2" r="0.15" fill="rgba(255,255,255,0.6)"/>
<circle cx="2" cy="13" r="0.2" fill="rgba(255,255,255,0.8)"/>

<defs>
<linearGradient id="shadowGradient" x1="0%" y1="0%" x2="100%" y2="100%">
<stop offset="0%" stop-color="#374151"/>
<stop offset="50%" stop-color="#4B5563"/>
<stop offset="100%" stop-color="#374151"/>
</linearGradient>
</defs>
</svg>