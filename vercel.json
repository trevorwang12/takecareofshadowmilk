{
  "version": 2,
  "name": "take-care-of-shadow-milk",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/game/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/take-care-of-shadow-milk",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/shadow-milk",
      "destination": "/",
      "permanent": true
    }
  ]
}